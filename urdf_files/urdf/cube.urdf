<?xml version="1.0"?>
<robot name="cube">
  <link name="cube_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.03"/>
      </geometry>
      <material name="Blue">
        <color rgba="0.2 0.4 0.9 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="7.5e-06" ixy="0" ixz="0"
               iyy="7.5e-06" iyz="0"
               izz="7.5e-06"/>
    </inertial>
  </link>
  <gazebo reference="cube_link">
    <mu1 value="1.0"/>
    <mu2 value="1.0"/>
  </gazebo>
</robot>
